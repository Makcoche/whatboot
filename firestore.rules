rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Ground Rule: Permitir operaciones en colecciones principales
    match /users/{userId} {
      allow read, write: if true;
    }
    match /chats/{chatId} {
      allow read, write: if true;
    }
    match /logs/{logId} {
      allow read, write: if true;
    }

    // Tenant Subcollections
    match /tenants/{tenantId} {
      allow read, write: if true;

      match /crm/{docId} {
        allow read, write: if true;
      }
      match /projects/{docId} {
        allow read, write: if true;
      }
      match /finance/{docId} {
        allow read, write: if true;
      }
    }
  }
}
